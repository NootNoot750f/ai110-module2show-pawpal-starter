classDiagram
    class User {
        -id: String
        -name: String
        -pets: List~Pet~
        +addPet(pet: Pet) void
        +getPets() List~Pet~
    }

    class Pet {
        -id: String
        -name: String
        -type: String
        -plans: List~Plan~
        +addPlan(plan: Plan) void
        +getPlans() List~Plan~
        +getTaskSheet() TaskSheet
    }

    class Plan {
        -id: String
        -name: String
        -description: String
        -createdAt: Date
        -tasks: List~Task~
        +addTask(task: Task) void
        +getTasks() List~Task~
    }

    class Task {
        -id: String
        -title: String
        -description: String
        -priority: String
        -dueDate: Date
        -completed: boolean
        +markComplete() void
        +updateTask(updates) void
    }

    class TaskSheet {
        -petId: String
        -tasks: List~Task~
        +getTaskList() List~Task~
        +filterByPriority(priority: String) List~Task~
    }

    class Scheduler {
        +buildSchedule(tasks: List~Task~) List~Event~
        +prioritize(tasks: List~Task~) List~Task~
    }

    class Event {
        -id: String
        -task: Task
        -scheduledTime: Date
        -durationMinutes: int
    }

    User "1" --> "*" Pet : has
    Pet "1" --> "*" Plan : has
    Plan "1" --> "*" Task : contains
    Pet "1" ..> "1" TaskSheet : derives
    TaskSheet "1" --> "*" Task : views
    Scheduler ..> Task : reads
    Scheduler "1" --> "*" Event : produces
    Event "1" --> "1" Task : wraps
